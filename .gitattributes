# Auto detect text files and normalize line endings on checkout
* text=auto

# Python sources: prefer LF on checkout (CI/Unix friendly), but allow Windows editing
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.spec text eol=lf

# Windows batch files need CRLF
*.bat text eol=crlf

# Binary files: do not normalize line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.zip binary
*.pdf binary
*.docx binary
*.doc binary
*.pyd binary
*.dll binary
*.exe binary
